# Gemini AI API key — required for OCR invoice processing.
# For local development: copy this file to .env.local and fill in real values.
# In AI Studio / Cloud Run: injected automatically from user secrets.
GEMINI_API_KEY="YOUR_APP_URL"

# Fallback for local Vite dev (supports VITE_ prefix as well)
VITE_GEMINI_API_KEY="YOUR_APP_URL"

# App URL — injected automatically by Cloud Run at runtime.
APP_URL="YOUR_APP_URL"
